---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

const categories = await getCollection('categories');
const paintings = await getCollection('paintings');
const expositions = await getCollection('expositions');
const settings = await getEntry('siteSettings', 'main');

categories.sort((a, b) => a.data.order - b.data.order);

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Cécile Callens',
  url: 'https://cecilecallens.art',
  jobTitle: 'Artiste peintre',
  email: 'cecilecallensartiste@gmail.com',
  sameAs: [],
});
---

<BaseLayout>
  <Fragment slot="json-ld">
    <script is:inline type="application/ld+json" set:html={jsonLd} />
  </Fragment>

  <main class="debug container">
    <h1>Content collections debug</h1>

    <section>
      <h2>Site settings</h2>
      {settings && (
        <ul>
          <li>Bio paragraphs: {settings.data.bioParagraphs.length}</li>
          <li>Contact: {settings.data.contactEmail} / {settings.data.contactPhone}</li>
          <li>Hero: {settings.data.heroHighlight.text}</li>
        </ul>
      )}
    </section>

    <section>
      <h2>Categories ({categories.length})</h2>
      <ul>
        {categories.map((cat) => (
          <li>{cat.data.order}. {cat.data.title} ({cat.data.slug})</li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Paintings ({paintings.length})</h2>
      {categories.map((cat) => {
        const catPaintings = paintings
          .filter((p) => p.data.category.id === cat.id)
          .sort((a, b) => a.data.order - b.data.order);
        return (
          <details>
            <summary>{cat.data.title} ({catPaintings.length})</summary>
            <ol>
              {catPaintings.map((p) => (
                <li>
                  {p.data.title} — {p.data.dimensions}, {p.data.technique}
                  {p.data.note && <em> [{p.data.note}]</em>}
                </li>
              ))}
            </ol>
          </details>
        );
      })}
    </section>

    <section>
      <h2>Expositions ({expositions.length})</h2>
      <ul>
        {expositions.map((expo) => (
          <li>{expo.data.title} — {expo.data.location} ({expo.data.startDate.toLocaleDateString('fr-FR')} - {expo.data.endDate.toLocaleDateString('fr-FR')})</li>
        ))}
      </ul>
    </section>
  </main>
</BaseLayout>

<style>
  .debug {
    padding-block: var(--space-xl);
  }

  .debug h1 {
    font-weight: 400;
    margin-block-end: var(--space-lg);
  }

  .debug h2 {
    font-weight: 400;
    margin-block: var(--space-md);
  }

  .debug section {
    margin-block-end: var(--space-lg);
  }

  .debug ul, .debug ol {
    list-style: disc;
    padding-inline-start: var(--space-lg);
  }

  .debug ol {
    list-style: decimal;
  }

  .debug details {
    margin-block: var(--space-sm);
  }

  .debug em {
    color: var(--color-grey);
  }
</style>
