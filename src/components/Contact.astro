---
import type { CollectionEntry } from 'astro:content';

interface Props {
  settings: CollectionEntry<'siteSettings'>;
}

const { settings } = Astro.props;
const { contactEmail, contactPhone } = settings.data;

const formattedPhone = contactPhone
  .replace(/^\+33/, '0')
  .replace(/(\d{2})(?=\d)/g, '$1 ');
---

<section id="contact" class="contact">
  <div class="contact__inner container">
    <h2 class="contact__heading">Contact</h2>
    <p class="contact__intro accent">Pour toute question, demande de renseignement ou visite de l'atelier.</p>
    <div class="contact__links">
      <a href={`mailto:${contactEmail}`} class="contact__link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <path d="M22 4L12 13 2 4"></path>
        </svg>
        <span>{contactEmail}</span>
      </a>
      <a href={`tel:${contactPhone}`} class="contact__link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"></path>
        </svg>
        <span>{formattedPhone}</span>
      </a>
    </div>
  </div>
</section>

<style>
  .contact {
    padding-block: var(--space-2xl);
    background: var(--color-bg);
    border-top: 1px solid var(--color-muted);
  }

  .contact__heading {
    font-family: var(--font-sans);
    font-weight: 100;
    font-size: var(--text-2xl);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: center;
    margin-bottom: var(--space-sm);
  }

  .contact__intro {
    text-align: center;
    color: var(--color-grey);
    font-size: var(--text-lg);
    margin-bottom: var(--space-xl);
  }

  .contact__links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .contact__link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-base);
    color: var(--color-dark);
    transition: color 0.2s;
  }

  .contact__link:hover,
  .contact__link:focus-visible {
    color: var(--color-grey);
  }

  @media (min-width: 36rem) {
    .contact__links {
      flex-direction: row;
      justify-content: center;
      gap: var(--space-xl);
    }
  }
</style>
